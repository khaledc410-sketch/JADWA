# JADWA Backend — Environment Variables
# Copy this file to .env and fill in the actual values.
# Never commit the real .env file to version control.

# ─── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=True

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://jadwa:jadwa_dev_pass@localhost:5432/jadwa

# ─── Cache / Queue (Redis) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-change-this

# ─── Anthropic / Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Object Storage (S3-compatible) ─────────────────────────────────────────
S3_BUCKET=jadwa-reports
AWS_ACCESS_KEY_ID=jadwa_minio
AWS_SECRET_ACCESS_KEY=jadwa_minio_dev_pass
AWS_REGION=me-south-1
# Leave blank to use AWS default endpoints; set for MinIO / Cloudflare R2, etc.
S3_ENDPOINT=http://localhost:9000
# Public endpoint for presigned URLs reachable from browser (MinIO dev)
S3_PUBLIC_ENDPOINT=http://localhost:9000

# ─── Moyasar (Saudi Payment Gateway) ────────────────────────────────────────
MOYASAR_SECRET_KEY=sk_...
MOYASAR_PUBLISHABLE_KEY=pk_...

# ─── Data Seed ───────────────────────────────────────────────────────────────
DATA_SEED_PATH=/data-seed
