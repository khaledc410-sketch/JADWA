  "nitaqat_special_cases": {
    "saudi_woman_multiplier": {
      "value": 1.0,
      "notes": "Saudi female employees count as 1 employee in standard Nitaqat calculations as of the 2024 regulatory update"
    },
    "disabled_employee_multiplier": {
      "value": 4.0,
      "notes": "Saudi employees with a certified disability registered with HRDF count as 4 Saudis toward Nitaqat"
    },
    "part_time_saudi_worker": {
      "multiplier": 0.5,
      "min_hours_per_week": 20,
      "notes": "Saudi part-time workers working minimum 20 hours per week count as 0.5 toward Nitaqat"
    },
    "remote_worker": {
      "multiplier": 1.0,
      "notes": "Saudi remote workers count fully toward Nitaqat if registered with GOSI and have a valid employment contract"
    },
    "student_worker": {
      "multiplier": 0.5,
      "notes": "Saudi students employed part-time during studies count as 0.5 toward Nitaqat"
    }
  },
  "compliance_calendar": {
    "quarterly_reporting": "Employers must update GOSI registration quarterly",
    "annual_nitaqat_review": "MHRSD reviews company Nitaqat band annually in January",
    "violation_grace_period_days": 90,
    "fine_per_illegal_worker_sar": 10000,
    "fine_for_fake_saudization_sar": 100000
  }
