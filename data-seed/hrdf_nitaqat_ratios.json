        "annuities_employee": 9.0,
        "unemployment_insurance_saned_employee": 1.0
      }
    },
    "expat_employee": {
      "employer_percent": 2.0,
      "employee_percent": 0,
      "total_percent": 2.0,
      "breakdown": {
        "occupational_hazard_employer": 2.0
      },
      "notes": "Expatriates are covered only for occupational hazards; no pension annuity or unemployment insurance contributions apply"
    }
