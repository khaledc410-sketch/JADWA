  "hrdf_subsidies": {
    "saudi_employee_year1": {
      "program_name_ar": "دعم توظيف السعوديين - السنة الأولى",
      "program_name_en": "Saudi Employment Support - Year 1",
      "percent_of_salary": 50,
      "max_monthly_sar": 3000,
      "duration_months": 12,
      "eligibility": "New Saudi hire registered with GOSI within 3 months of joining",
      "notes": "Applies to first-time private sector employees and those unemployed for more than 6 months"
    },
    "saudi_employee_year2": {
      "program_name_ar": "دعم توظيف السعوديين - السنة الثانية",
      "program_name_en": "Saudi Employment Support - Year 2",
      "percent_of_salary": 25,
      "max_monthly_sar": 1500,
      "duration_months": 12,
      "eligibility": "Employee must have completed Year 1 support period with same employer",
      "notes": "Continuation of Year 1 support at a reduced rate"
    },
    "female_employment_bonus": {
      "program_name_ar": "مكافأة توظيف المرأة السعودية",
      "program_name_en": "Saudi Female Employment Bonus",
      "monthly_sar": 1000,
      "max_duration_months": 24,
      "eligibility": "New Saudi female hire in eligible private sector roles",
      "notes": "Stackable with Year 1 and Year 2 salary support programs"
    },
    "on_job_training": {
      "program_name_ar": "برنامج التدريب أثناء العمل - تقاط",
      "program_name_en": "On-the-Job Training Program (TAQAT)",
      "monthly_allowance_sar": 2000,
      "max_duration_months": 6,
      "employer_subsidy_percent": 75,
      "eligibility": "Saudi nationals enrolled in HRDF-approved OJT programs",
      "notes": "Trainee counts partially toward Nitaqat during training period"
    },
    "training_programs": [
      {
        "name_ar": "برنامج نافس",
        "name_en": "Nafis Program",
        "provider": "Empower - National Programme to Empower Saudi National Citizens",
        "monthly_support_sar": 4000,
        "max_duration_months": 36,
        "target_sectors": ["all_private_sector"],
        "description_en": "Monthly salary supplement for Saudi employees in the private sector to bridge the wage gap with public sector employment"
      },
      {
        "name_ar": "برنامج تمهير",
        "name_en": "Tamheer Internship Program",
        "provider": "HRDF",
        "monthly_stipend_sar": 2000,
        "duration_months": 6,
        "max_extension_months": 6,
        "target_group": "Fresh Saudi graduates (within 3 years of graduation)",
        "description_en": "Structured internship providing fresh Saudi graduates with practical private sector experience, HRDF pays full stipend"
      },
      {
        "name_ar": "برنامج التدريب الانتاجي",
        "name_en": "Productive Training Program",
        "provider": "HRDF",
        "subsidy_percent": 50,
        "max_monthly_sar": 1500,
        "duration_months": 12,
        "description_en": "Subsidizes employer cost of training Saudi employees in operational and technical roles"
      },
      {
        "name_ar": "برنامج تطوير القدرات البشرية",
        "name_en": "Human Capability Development Program (HCDP)",
        "provider": "HRDF",
        "max_grant_sar": 50000,
        "duration_weeks": 16,
        "target_sectors": ["fnb", "retail", "healthcare", "it_tech", "logistics"],
        "description_en": "Upskilling and reskilling program for Saudi nationals transitioning into high-demand private sector roles"
      },
      {
        "name_ar": "برنامج لافت",
        "name_en": "LAFT - Training Fund for Establishments",
        "provider": "HRDF",
        "subsidy_percent": 50,
        "max_grant_sar": 500000,
        "eligibility": "Establishments with 50+ employees",
        "description_en": "Co-finances employer-led training initiatives to upskill Saudi workforce in priority sectors"
      }
    ]
  },
  "gosi_rates": {
    "notes": "General Organization for Social Insurance (GOSI) contribution rates effective 2024. Contributions calculated on basic salary plus housing allowance.",
