  "curriculum_requirements": {
    "section_name_ar": "اشتراطات المناهج الدراسية",
    "section_name_en": "MOE Curriculum Requirements",
    "national_curriculum": {
      "name_ar": "المنهج الوطني السعودي",
      "name_en": "Saudi National Curriculum",
      "mandatory_for": "All private schools unless approved for international curriculum",
      "subjects_ar": ["اللغة العربية", "التربية الإسلامية", "الرياضيات", "العلوم", "الدراسات الاجتماعية", "اللغة الإنجليزية", "التربية البدنية", "التربية الفنية", "المهارات الرقمية"],
      "subjects_en": ["Arabic Language", "Islamic Studies", "Mathematics", "Science", "Social Studies", "English Language", "Physical Education", "Art Education", "Digital Skills"],
      "notes_en": "All private schools using national curriculum must follow MOE textbooks and assessment standards. Digital Skills added as mandatory subject from Grade 4."
    },
    "international_curricula": [
      {
        "id": "CUR-001",
        "name_ar": "البكالوريا الدولية (IB)",
        "name_en": "International Baccalaureate (IB)",
        "accreditation_body": "International Baccalaureate Organization (IBO)",
        "accreditation_fee_sar": 75000,
        "annual_fee_sar": 40000,
        "accreditation_timeline_months": 24,
        "moe_conditions": [
          "Must teach Arabic language (minimum 4 periods/week)",
          "Must teach Islamic studies for Muslim students (minimum 2 periods/week)",
          "Must teach Saudi national studies/social studies",
          "MOE approval required before applying to IBO"
        ]
      },
      {
        "id": "CUR-002",
        "name_ar": "المنهج البريطاني (IGCSE / A-Levels)",
        "name_en": "British Curriculum (IGCSE / A-Levels)",
        "accreditation_body": "Cambridge Assessment International Education / Pearson Edexcel",
        "accreditation_fee_sar": 50000,
        "annual_fee_sar": 30000,
        "accreditation_timeline_months": 12,
        "moe_conditions": [
          "Must teach Arabic language (minimum 4 periods/week)",
          "Must teach Islamic studies for Muslim students (minimum 2 periods/week)",
          "Must teach Saudi national studies/social studies",
          "MOE approval required"
        ]
      },
      {
        "id": "CUR-003",
        "name_ar": "المنهج الأمريكي",
        "name_en": "American Curriculum",
        "accreditation_body": "AdvancED / NEASC / MSA / WASC",
        "accreditation_fee_sar": 55000,
        "annual_fee_sar": 25000,
        "accreditation_timeline_months": 18,
        "moe_conditions": [
          "Must teach Arabic language (minimum 4 periods/week)",
          "Must teach Islamic studies for Muslim students (minimum 2 periods/week)",
          "Must teach Saudi national studies/social studies",
          "MOE approval required",
          "High school diploma must be attested by MOE for local university admission"
        ]
      }
    ],
    "arabic_language_mandate": {
      "name_ar": "اشتراطات تدريس اللغة العربية",
      "name_en": "Arabic Language Teaching Requirements",
      "min_periods_per_week_national": 7,
      "min_periods_per_week_international": 4,
      "qualified_teacher_required": true,
      "teacher_qualification": "BA in Arabic Language or Arabic Language Education",
      "notes_en": "Arabic language instruction is mandatory in all private schools regardless of curriculum. International schools must allocate a minimum of 4 periods per week."
    },
    "islamic_studies_mandate": {
      "name_ar": "اشتراطات تدريس التربية الإسلامية",
      "name_en": "Islamic Studies Requirements",
      "applicable_to": "All Muslim students in all school types",
      "min_periods_per_week_national": 4,
      "min_periods_per_week_international": 2,
      "qualified_teacher_required": true,
      "teacher_qualification": "BA in Islamic Studies or Islamic Education",
      "notes_en": "Islamic studies mandatory for all Muslim students. Non-Muslim students may be exempted with parental written request. Quran memorization programs are encouraged but not mandatory."
    },
    "physical_education_mandate": {
      "name_ar": "اشتراطات التربية البدنية",
      "name_en": "Physical Education Requirements",
      "min_periods_per_week": 2,
      "applicable_to": "All students (male and female)",
      "notes_en": "Physical education is mandatory for all students in all school types. Girls' PE was officially introduced in 2017. Schools must have adequate indoor or outdoor sports facilities."
    }
  },
